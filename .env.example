# ════════════════════════════════════════════════════════════════════════════
# Aliança Log — variáveis de ambiente
# ────────────────────────────────────────────────────────────────────────────
# Copie este arquivo para .env.local e preencha com os dados do projeto Supabase
# (região sa-east-1). O .env.local NÃO é versionado; este .env.example é.
#
#   cp .env.example .env.local
#
# Onde achar as chaves: Supabase Dashboard → Project Settings → API.
# NUNCA preencha valores reais aqui — eles vão no .env.local.
# ════════════════════════════════════════════════════════════════════════════

# ── Supabase (público, exposto ao browser) ──────────────────────────────────
# URL do projeto, ex.: https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública do cliente. Use a "anon key" clássica OU a nova "publishable key"
# (o código aceita qualquer uma das duas — basta preencher uma).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ── Supabase (servidor — SECRETO, nunca expor ao browser) ───────────────────
# service_role key (ou nova "secret key" sb_secret_...). Ignora o RLS. Usada só
# no servidor para criar logins, assinar URLs das fotos e no seed (npm run seed).
SUPABASE_SERVICE_ROLE_KEY=

# Senha do banco (não usada pela app; útil para conexão direta / migrations).
SUPABASE_PASSWORD=

# ── Conexão direta ao Postgres (para migrations e backup) ───────────────────
# Usada por scripts/migrate.mjs, migrate-status.mjs e backup.mjs
# (npm run db:migrate / db:status / db:backup).
# Pegue em: Supabase → Project Settings → Database → Connection string →
# "Session pooler" (porta 5432; é compatível com pg_dump, o pooler 6543 não é).
# Formato: postgresql://postgres.<ref>:<senha>@aws-1-sa-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=
